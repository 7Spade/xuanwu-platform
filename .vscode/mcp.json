{
  "inputs": [
    {
      "id": "agentMemoryRedisUrl",
      "type": "promptString",
      "description": "Redis URL for agent-memory-server (e.g. rediss://default:PASSWORD@host:port)",
      "password": true
    },
    {
      "id": "agentMemoryOpenaiKey",
      "type": "promptString",
      "description": "OpenAI API key for agent-memory-server embeddings and generation",
      "password": true
    },
    {
      "id": "upstashEmail",
      "type": "promptString",
      "description": "Upstash account email (console.upstash.com)"
    },
    {
      "id": "upstashApiKey",
      "type": "promptString",
      "description": "Upstash Management API key (console.upstash.com → Account → API Keys)",
      "password": true
    }
  ],
  "servers": {
    "agent-memory": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "agent-memory-server", "agent-memory", "mcp"],
      "env": {
        "REDIS_URL": "${input:agentMemoryRedisUrl}",
        "OPENAI_API_KEY": "${input:agentMemoryOpenaiKey}",
        "DISABLE_AUTH": "true"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${workspaceFolder}"]
    },
    "repomix": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "repomix", "--mcp"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "software-planning": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "github:NightTrek/Software-planning-mcp"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "next-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "markitdown": {
      "type": "stdio",
      "command": "uvx",
      "args": ["markitdown-mcp"]
    },
    "everything": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"]
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}"
      ]
    },
    "firebase-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"],
      "env": {
        "FIREBASE_PROJECT_ID": "xuanwu-i-00708880-4e2d8"
      }
    },
    "upstash": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/mcp-server@latest",
        "--email",
        "${input:upstashEmail}",
        "--api-key",
        "${input:upstashApiKey}"
      ]
    }
  }
}
